    "def billing_and_deallocate():\n",
    "    \"\"\"\n",
    "    Menu Option 6 - Billing and De-Allocation\n",
    "    Generates an invoice with GST and frees the room after checkout.\n",
    "    Built-in functions used: input(), round(), remove(), print()\n",
    "    \"\"\"\n",
    "    print(\"\\n--- BILLING AND DE-ALLOCATION ---\")\n",
    "    try:\n",
    "        if len(allocations) == 0:\n",
    "            raise IndexError(\"No active allocations found.\")\n",
    "\n",
    "        room_number = input(\"Enter Room Number for Checkout: \").strip()\n",
    "\n",
    "        for alloc in allocations:\n",
    "            if alloc[\"room_number\"] == room_number:\n",
    "                subtotal   = alloc[\"nights\"] * alloc[\"price_per_night\"]\n",
    "                gst_rate   = 0.15\n",
    "\n",
    "                # Guard against zero GST rate (ZeroDivisionError example)\n",
    "                if gst_rate == 0:\n",
    "                    raise ZeroDivisionError(\"GST rate cannot be zero.\")\n",
    "\n",
    "                gst_amount = round(subtotal * gst_rate, 2)\n",
    "                total      = round(subtotal + gst_amount, 2)\n",
    "\n",
    "                print(\"\\n\" + \"=\" * 50)\n",
    "                print(\"       LANGHAM HOTEL - INVOICE\")\n",
    "                print(\"=\" * 50)\n",
    "                print(f\"  Customer  : {alloc['customer_name']}\")\n",
    "                print(f\"  Room No   : {alloc['room_number']}\")\n",
    "                print(f\"  Room Type : {alloc['room_type']}\")\n",
    "                print(f\"  Check-in  : {alloc['check_in']}\")\n",
    "                print(f\"  Nights    : {alloc['nights']}\")\n",
    "                print(f\"  Rate/Night: NZD {alloc['price_per_night']:.2f}\")\n",
    "                print(\"-\" * 50)\n",
    "                print(f\"  Subtotal  : NZD {subtotal:.2f}\")\n",
    "                print(f\"  GST (15%) : NZD {gst_amount:.2f}\")\n",
    "                print(f\"  TOTAL DUE : NZD {total:.2f}\")\n",
    "                print(\"=\" * 50)\n",
    "\n",
    "                # Free the room after checkout\n",
    "                for room in rooms:\n",
    "                    if room[\"room_number\"] == room_number:\n",
    "                        room[\"status\"] = \"Available\"\n",
    "\n",
    "                allocations.remove(alloc)\n",
    "                print(f\"\\n  Room {room_number} is now available for next booking.\")\n",
    "                return\n",
    "\n",
    "        print(f\"No active allocation found for Room {room_number}.\")\n",
    "\n",
    "    except IndexError as e:\n",
    "        print(f\"[IndexError] {e}\")\n",
    "    except ZeroDivisionError as e:\n",
    "        print(f\"[ZeroDivisionError] {e}\")\n",
    "    except TypeError as e:\n",
    "        print(f\"[TypeError] {e}\")\n",
    "\n",
    "print(\"Function billing_and_deallocate() defined.\")"
   ]
