    "def allocate_room():\n",
    "    \"\"\"\n",
    "    Menu Option 4 - Allocate Room\n",
    "    Books an available room for a customer.\n",
    "    Built-in functions used: input(), int(), str(), append(), print()\n",
    "    \"\"\"\n",
    "    print(\"\\n--- ALLOCATE ROOM ---\")\n",
    "    try:\n",
    "        if len(rooms) == 0:\n",
    "            raise IndexError(\"No rooms available for allocation.\")\n",
    "\n",
    "        room_number   = input(\"Enter Room Number to Book: \").strip()\n",
