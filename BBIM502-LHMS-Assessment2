    "def delete_room():\n",
    "    \"\"\"\n",
    "    Menu Option 2 - Delete Room\n",
    "    Removes a room from the list if it is not currently booked.\n",
    "    Built-in functions used: input(), len(), remove(), print()\n",
    "    \"\"\"\n",
    "    print(\"\\n--- DELETE ROOM ---\")\n",
    "    try:\n",
    "        if len(rooms) == 0:\n",
    "            raise IndexError(\"No rooms available to delete.\")\n",
    "\n",
    "        room_number = input(\"Enter Room Number to Delete: \").strip()\n",
    "\n",
    "        # Do not allow deletion if room is currently booked\n",
    "        for alloc in allocations:\n",
    "            if alloc[\"room_number\"] == room_number:\n",
    "                print(f\"Cannot delete Room {room_number} - it is currently allocated.\")\n",
    "                return\n",
    "\n",
    "        for room in rooms:\n",
    "            if room[\"room_number\"] == room_number:\n",
    "                rooms.remove(room)\n",
    "                print(f\"\\n  Room {room_number} deleted successfully.\")\n",
    "                return\n",
    "\n",
    "        print(f\"Room {room_number} not found.\")\n",
    "\n",
    "    except IndexError as e:\n",
    "        print(f\"[IndexError] {e}\")\n",
    "    except NameError as e:\n",
    "        print(f\"[NameError] {e}\")\n",
    "\n",
    "print(\"Function delete_room() defined.\")"
