    "def backup_and_clear_file():\n",
    "    \"\"\"\n",
    "    Menu Option 9 - Backup and Clear File\n",
    "    Copies main file into a timestamped backup then clears the original.\n",
    "    Built-in functions used: open(), read(), write(), close(), strftime()\n",
    "    \"\"\"\n",
    "    print(\"\\n--- BACKUP AND CLEAR FILE ---\")\n",
    "    student_id      = \"850008172\"\n",
    "    filename        = f\"LHMS_{850008172}.txt\"\n",
    "    timestamp       = datetime.datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "    backup_filename = f\"LHMS_{student_id}_Backup_{timestamp}.txt\"\n",
    "    try:\n",
    "        # Step 1: Read original file\n",
    "        source_file = open(filename, \"r\")\n",
    "        content     = source_file.read()\n",
    "        source_file.close()\n",
    "\n",
    "        if not content.strip():\n",
    "            raise EOFError(\"The source file is empty. Nothing to back up.\")\n",
    "\n",
    "        # Step 2: Append to backup file\n",
    "        backup_file = open(backup_filename, \"a\")\n",
    "        backup_file.write(content)\n",
    "        backup_file.close()\n",
    "        print(f\"  Backup saved to '{backup_filename}'.\")\n",
    "\n",
    "        # Step 3: Clear the original file\n",
    "        clear_file = open(filename, \"w\")\n",
    "        clear_file.write(\"\")\n",
    "        clear_file.close()\n",
    "        print(f\"  Original file '{filename}' has been cleared.\")\n",
    "\n",
    "    except FileNotFoundError:\n",
    "        print(f\"[FileNotFoundError] '{filename}' not found. Save data first (Option 7).\")\n",
    "    except IOError as e:\n",
    "        print(f\"[IOError] File operation failed: {e}\")\n",
    "    except EOFError as e:\n",
    "        print(f\"[EOFError] {e}\")\n",
    "\n",
    "print(\"Function backup_and_clear_file() defined.\")"
   ]
