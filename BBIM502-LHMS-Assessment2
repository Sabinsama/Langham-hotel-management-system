    "def add_room():\n",
    "    \"\"\"\n",
    "    Menu Option 1 - Add Room\n",
    "    Adds a new room to the rooms list.\n",
    "    Built-in functions used: input(), float(), int(), append(), print()\n",
    "    \"\"\"\n",
    "    print(\"\\n--- ADD ROOM ---\")\n",
    "    try:\n",
    "        room_number = input(\"Enter Room Number: \").strip()\n",
    "\n",
    "        # Check if room already exists\n",
    "        for room in rooms:\n",
    "            if room[\"room_number\"] == room_number:\n",
    "                print(f\"Room {room_number} already exists!\")\n",
    "                return\n",
    "\n",
    "        room_type = input(\"Enter Room Type (Single/Double/Suite): \").strip()\n",
    "\n",
    "        # ValueError raised if user types letters for price\n",
    "        price = float(input(\"Enter Price per Night (NZD): \"))\n",
    "        if price <= 0:\n",
    "            raise ValueError(\"Price must be greater than zero.\")\n",
    "\n",
    "        floor = int(input(\"Enter Floor Number: \"))\n",
    "\n",
    "        new_room = {\n",
    "            \"room_number\": room_number,\n",
    "            \"room_type\":   room_type,\n",
    "            \"price\":       price,\n",
    "            \"floor\":       floor,\n",
    "            \"status\":      \"Available\"\n",
    "        }\n",
    "        rooms.append(new_room)\n",
    "        print(f\"\\n  Room {room_number} added successfully!\")\n",
    "\n",
    "    except ValueError as e:\n",
    "        print(f\"[ValueError] Invalid input: {e}\")\n",
    "    except OverflowError:\n",
    "        print(\"[OverflowError] The number entered is too large.\")\n",
    "\n",
    "print(\"Function add_room() defined. Call add_room() to test.\")"
